  "lecture_summary": {
    "present": true,
    "summary_lines": [
      "Forelæsningen samler klassiske og nyere diskussioner af, hvad der kan tælle som empiri i psykoanalysen.",
      "Kilderne viser, at kliniske fortællinger, overføring, fortolkning og psykisk realitet ikke kan adskilles skarpt fra teoridannelse.",
      "Psykoanalysens metode fremstilles derfor som en fortolkende praksis, der må begrunde sine sandhedskrav uden at reducere subjektet til målbare størrelser."
    ],
    "key_points": [
      "Det kliniske materiale er meningsfuldt og relationelt, ikke blot observationsdata.",
      "Psykisk realitet og fortælling er centrale elementer i psykoanalytisk evidens.",
      "Metodekritik handler om, hvordan fortolkning kan gøres fagligt ansvarlig.",
      "Spændingen mellem videnskabelighed og klinisk singularitet er konstitutiv for feltet."
    ]
  },
